# ============================================
# StowStack Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Vercel KV (Redis) ---
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Vercel Postgres ---
STORAGE_POSTGRES_URL=

# --- Resend (transactional email) ---
RESEND_API_KEY=

# --- Anthropic (AI copy generation + diagnostics) ---
ANTHROPIC_API_KEY=

# --- Admin auth ---
ADMIN_SECRET=

# --- Cron job auth ---
CRON_SECRET=

# --- Meta / Facebook ---
META_APP_ID=
META_APP_SECRET=
META_PIXEL_ID=
META_ACCESS_TOKEN=
FB_APP_SECRET=

# --- Google Ads ---
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_CONVERSION_ID=
GOOGLE_CONVERSION_LABEL=

# --- Google Places ---
GOOGLE_PLACES_API_KEY=

# --- Unsplash (stock images) ---
UNSPLASH_ACCESS_KEY=

# --- Site URL (auto-set on Vercel, override for local dev) ---
# NEXT_PUBLIC_SITE_URL=http://localhost:5173
# BASE_URL=http://localhost:5173

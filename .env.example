# ============================================
# StowStack Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Vercel KV (Redis) ---
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Vercel Postgres ---
STORAGE_POSTGRES_URL=

# --- Resend (transactional email) ---
RESEND_API_KEY=

# --- Anthropic (AI copy generation + diagnostics) ---
ANTHROPIC_API_KEY=

# --- Admin auth ---
ADMIN_SECRET=

# --- Cron job auth ---
CRON_SECRET=

# --- Meta / Facebook ---
META_APP_ID=
META_APP_SECRET=
META_PIXEL_ID=
META_ACCESS_TOKEN=
FB_APP_SECRET=

# --- Google Ads ---
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_CONVERSION_ID=
GOOGLE_CONVERSION_LABEL=

# --- Google Places ---
GOOGLE_PLACES_API_KEY=

# --- Unsplash (stock images) ---
UNSPLASH_ACCESS_KEY=

# --- Push Notifications (VAPID / Web Push) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:blake@stowstack.co

# --- Site URL (auto-set on Vercel, override for local dev) ---
# NEXT_PUBLIC_SITE_URL=http://localhost:5173
# BASE_URL=http://localhost:5173

# ============================================
# Open Source Plugins (all optional, free tiers)
# ============================================

# --- PostHog (product analytics, session replay, A/B testing, feature flags) ---
# Free: 1M events/mo, 5K sessions | https://posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Umami (privacy-friendly analytics, no cookies) ---
# Free: 10K events/mo cloud, unlimited self-hosted | https://umami.is
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SRC=https://cloud.umami.is/script.js
# VITE_UMAMI_RESPECT_DNT=true

# --- Chatwoot (live chat widget on landing pages) ---
# Free self-hosted | https://chatwoot.com
VITE_CHATWOOT_TOKEN=
VITE_CHATWOOT_BASE_URL=https://app.chatwoot.com

# --- Cal.com (tour scheduling on landing pages) ---
# Free for 1 user | https://cal.com
VITE_CALCOM_LINK=

# --- Formbricks (surveys & NPS after move-in, reservation, etc.) ---
# Free: 500 responses/mo | https://formbricks.com
VITE_FORMBRICKS_ENV_ID=
VITE_FORMBRICKS_API_HOST=https://app.formbricks.com

# --- Novu (multi-channel notifications: email + SMS + push) ---
# Free: 30K events/mo | https://novu.co
VITE_NOVU_API_KEY=
VITE_NOVU_API_URL=https://api.novu.co/v1

# --- n8n (workflow automation webhooks) ---
# Free self-hosted | https://n8n.io
VITE_N8N_WEBHOOK_URL=

# --- Langfuse (LLM observability for AI copy generation) ---
# Free: 50K observations/mo | https://langfuse.com
VITE_LANGFUSE_PUBLIC_KEY=
VITE_LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Nominatim (geocoding — no key needed, rate-limited 1 req/sec) ---
# Free: unlimited | https://nominatim.org

# --- GrapesJS (drag-and-drop page builder — MIT license) ---
# Free: unlimited | https://grapesjs.com
# Requires: npm install grapesjs grapesjs-preset-webpage
